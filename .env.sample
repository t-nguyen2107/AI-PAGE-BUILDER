# ===========================================
# AI Page Builder — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
#   cp .env.sample .env.local

# ---------- Database ----------
# Direct connection (for Prisma CLI: db push, migrate, studio)
DATABASE_URL="postgresql://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Accelerate connection (for app runtime — connection pooling, edge caching)
# Get this from console.prisma.io → your database → Accelerate tab
# In .env.local, set DATABASE_URL to this value to enable connection pooling:
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ---------- AI Provider ----------
# Provider: openai | ollama | anthropic
# (OpenRouter uses "openai" provider with OpenRouter base URL)
AI_PROVIDER="openai"

# ---------- Option 1: OpenRouter (recommended — free models available) ----------
# Sign up at https://openrouter.ai
AI_BASE_URL="https://openrouter.ai/api/v1"
AI_API_KEY="sk-or-v1-YOUR_KEY"

# Free models (pick one):
AI_MODEL="deepseek/deepseek-chat-v3-0324:free"
# AI_MODEL="qwen/qwen3.6-plus:free"
# AI_MODEL="minimax/minimax-m2.5:free"
# AI_MODEL="google/gemma-3-27b-it:free"

# ---------- Option 2: Ollama (local, no API key needed) ----------
# AI_PROVIDER="ollama"
# AI_BASE_URL="http://localhost:11434"
# AI_MODEL="qwen3.5"
# AI_API_KEY=""

# ---------- Option 3: OpenAI ----------
# AI_PROVIDER="openai"
# AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL="gpt-4o"
# AI_API_KEY="sk-YOUR_KEY"

# ---------- Option 4: Anthropic ----------
# AI_PROVIDER="anthropic"
# AI_BASE_URL="https://api.anthropic.com"
# AI_MODEL="claude-sonnet-4-6-20250514"
# AI_API_KEY="sk-ant-YOUR_KEY"

# ---------- Generation params (optional) ----------
AI_TEMPERATURE="0.7"
AI_MAX_RETRIES="2"
AI_MAX_TOKENS="16384"
