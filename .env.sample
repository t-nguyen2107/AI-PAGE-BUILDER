# ===========================================
# AI Page Builder — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
#   cp .env.sample .env.local

# ---------- Database ----------
# Direct connection (for Prisma CLI: migrate, push, studio)
# Local:   postgresql://user:password@localhost:5432/pagedb
# Prisma:  postgresql://user:password@db.prisma.io:5432/postgres?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/pagedb"

# Accelerate connection (for app runtime — connection pooling, edge caching)
# Get this from console.prisma.io → your database → Accelerate tab
DATABASE_ORM="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ---------- AI Provider ----------
# Provider: ollama | openai | anthropic
AI_PROVIDER="ollama"

# Model name (default varies by provider)
AI_MODEL="qwen3.5"

# Base URL for Ollama or compatible API
AI_BASE_URL="http://localhost:11434"

# API key (required for openai / anthropic, leave empty for ollama)
AI_API_KEY=""

# Generation params
AI_TEMPERATURE="0.7"
AI_MAX_RETRIES="2"
AI_MAX_TOKENS="16384"

# ---------- Deprecated (still works) ----------
# OLLAMA_BASE_URL — use AI_BASE_URL instead
# OLLAMA_MODEL    — use AI_MODEL instead
