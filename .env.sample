# ===========================================
# LoomWeave — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
#   cp .env.sample .env.local
#
# Next.js loads .env.local AFTER .env, so values there take precedence.
# Prisma CLI reads .env only (uses DATABASE_DIRECT_URL for db push/migrate).

# ---------- Database ----------
# Direct connection — for Prisma CLI (db push, migrate, studio)
DATABASE_URL="postgresql://user:password@db.prisma.io:5432/postgres?sslmode=require"
DATABASE_DIRECT_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# Accelerate connection — for app runtime (connection pooling, edge caching)
# Get this from console.prisma.io → your database → Accelerate tab
# In production (Vercel), set DATABASE_URL to this Accelerate URL:
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ===========================================
# AI Provider Configuration
# ===========================================
# Provider: gemini | openai | ollama | anthropic
AI_PROVIDER="gemini"

# ---------- Main Model (full generation, heavy chain) ----------
AI_MODEL="gemini-3-flash-preview"
AI_API_KEY="YOUR_GEMINI_API_KEY"

# Base URL — only needed for OpenAI-compatible providers (not Gemini/Ollama)
# AI_BASE_URL="https://api.openai.com/v1"

# ---------- Fast Model (template mode, wizard chat, styleguide) ----------
# Falls back to main model if not set.
# Uses lighter model for faster responses (~3s vs ~7s).
AI_FAST_MODEL="gemini-3.1-flash-lite-preview"
AI_FAST_API_KEY="YOUR_GEMINI_API_KEY"

# Base URL for fast model (optional, falls back to AI_BASE_URL)
# AI_FAST_BASE_URL=""

# ---------- Generation Parameters (optional) ----------
AI_TEMPERATURE="0.7"
AI_MAX_RETRIES="2"
AI_MAX_TOKENS="16384"

# ===========================================
# Alternative AI Providers (uncomment to switch)
# ===========================================

# ---------- Option 1: Gemini (recommended) ----------
# AI_PROVIDER="gemini"
# AI_MODEL="gemini-3-flash-preview"
# AI_API_KEY="YOUR_GEMINI_API_KEY"
#
# Get API key: https://aistudio.google.com/apikey
# Pricing: ~$0.15/1M input, ~$0.60/1M output tokens

# ---------- Option 2: OpenRouter (multiple models) ----------
# AI_PROVIDER="openai"
# AI_BASE_URL="https://openrouter.ai/api/v1"
# AI_MODEL="google/gemini-3-flash-preview"
# AI_API_KEY="sk-or-v1-YOUR_KEY"

# ---------- Option 3: OpenAI ----------
# AI_PROVIDER="openai"
# AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL="gpt-4o"
# AI_API_KEY="sk-YOUR_KEY"

# ---------- Option 4: Anthropic ----------
# AI_PROVIDER="anthropic"
# AI_MODEL="claude-sonnet-4-6-20250514"
# AI_API_KEY="sk-ant-YOUR_KEY"

# ---------- Option 5: Ollama (local, free) ----------
# AI_PROVIDER="ollama"
# AI_BASE_URL="http://localhost:11434"
# AI_MODEL="qwen3.5"
# AI_API_KEY=""

# ===========================================
# Embedding Provider (for AI Memory / pgvector)
# ===========================================
# Provider: gemini | openai | ollama
# "openai" provider supports OpenAI-compatible APIs (e.g. Jina)
# When AI_PROVIDER="gemini", embeddings default to Gemini automatically.

# ---------- Option 1: Gemini (recommended — same API key as AI_PROVIDER) ----------
EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="text-embedding-004"
EMBEDDING_API_KEY="YOUR_GEMINI_API_KEY"
EMBEDDING_DIMENSIONS="768"
# No EMBEDDING_BASE_URL needed — uses Google's API directly.


# ---------- Option 2: Jina (free tier, OpenAI-compatible) ----------
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_BASE_URL="https://api.jina.ai/v1"
# EMBEDDING_API_KEY="YOUR_JINA_API_KEY"
# EMBEDDING_MODEL="jina-embeddings-v2-base-en"
# EMBEDDING_DIMENSIONS="768"
# Get free Jina API key: https://jina.ai/embeddings/

# ---------- Option 3: Ollama (local, free) ----------
# EMBEDDING_PROVIDER="ollama"
# EMBEDDING_BASE_URL="http://localhost:11434"
# EMBEDDING_MODEL="nomic-embed-text"
# EMBEDDING_DIMENSIONS="768"

# ---------- Option 4: OpenAI ----------
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_API_KEY="sk-YOUR_KEY"
# EMBEDDING_MODEL="text-embedding-3-small"
# EMBEDDING_DIMENSIONS="1536"
