        @media (min-width: 768px) {
          /* Container shape & spacing */
          .create-box-hero > div,
          .create-box-hero [role="presentation"] {
            border-radius: 28px;
          }
          .create-box-hero [role="presentation"] {
            padding: 24px;
            min-height: 280px;
          }

          /* Editor text sizing */
          .create-box-hero .create-tiptap {
            min-height: 140px;
            margin-bottom: 16px;
          }
          .create-box-hero .ProseMirror {
            font-size: 24px;
            line-height: 32px;
          }
          .create-box-hero .ProseMirror .is-editor-empty::before {
            font-size: 24px;
            line-height: 32px;
          }

          /* Toolbar items: bump from 36px (size-9) to 48px */
          .create-box-hero .create-tiptap ~ div [role="radiogroup"] {
            height: auto;
            padding: 4px;
          }
          .create-box-hero .create-tiptap ~ div [role="radiogroup"] button {
            padding: 10px 18px;
          }
          .create-box-hero .create-tiptap ~ div > div button:not([role="radio"]),
          .create-box-hero .create-tiptap ~ div > div > div button:not([role="radio"]) {
            min-height: 48px;
          }

          /* Generate & attach buttons */
          .create-box-hero .create-tiptap ~ div button[class*="size-9"] {
            width: 48px;
            height: 48px;
          }

          /* Model picker */
          .create-box-hero .create-tiptap ~ div [class*="h-9"] {
            height: 48px;
          }
        }
