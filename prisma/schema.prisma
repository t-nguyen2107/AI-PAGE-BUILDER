generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// CORE ENTITIES
// ===========================================

model Project {
  id           String   @id @default(cuid())
  name         String
  description  String?
  thumbnailUrl String?
  siteName     String?   // Display name for the website
  companyName  String?   // Legal/company name
  logo         String?   // Logo image URL
  favicon      String?   // Favicon URL
  gaCode           String?   // Google Analytics tracking ID
  headScripts      String?   // Raw HTML for <head>
  bodyScripts      String?   // Raw HTML for before-</body>
  language         String?   @default("en")        // Default site language
  socialLinks      String?   @default("{}")        // JSON { facebook, twitter, instagram, linkedIn, youtube, tikTok }
  contactInfo      String?   @default("{}")        // JSON { email, phone, address }
  metaVerification String?   @default("{}")        // JSON { google, bing }
  defaultOgImage   String?                          // Fallback OG image for all pages
  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pages          Page[]
  styleguide     Styleguide?
  globalSections GlobalSection[]
  aiProfile      ProjectAIProfile?
  aiMemories     VectorEmbedding[]

  @@map("projects")
}

model Page {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  slug           String
  order          Int      @default(0)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  canonicalUrl   String?
  robots         String?   @default("index, follow")
  twitterCard    String?   @default("summary")
  twitterImage   String?
  structuredData String?   @default("{}")
  isHomePage       Boolean  @default(false)
  generationStatus String?  @default(dbgenerated("NULL")) // null=normal, "pending"=skeleton, "polishing"=in-progress, "complete"=done
  treeData         String   // JSON string — serialized PageNode tree

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions Revision[]

  @@unique([projectId, slug])
  @@map("pages")
}

model Styleguide {
  id        String @id @default(cuid())
  projectId String @unique
  name      String @default("Default Styleguide")

  colors             String @default("{}") // JSON — ColorPalette
  typography         String @default("{}") // JSON — TypographySystem
  spacing            String @default("{}") // JSON — SpacingScale
  componentVariants  String @default("[]") // JSON — ComponentVariant[]
  cssVariables       String @default("{}") // JSON — Record<string, string>

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("styleguides")
}

model GlobalSection {
  id          String @id @default(cuid())
  projectId   String
  sectionType String // "header", "footer", "nav", "custom"
  sectionName String
  treeData    String // JSON — SectionNode

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sectionType])
  @@map("global_sections")
}

model Revision {
  id       String @id @default(cuid())
  pageId   String
  snapshot String  // JSON — PageNode tree snapshot
  label    String?
  diff     String? // JSON — optional JsonPatch[]

  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@map("revisions")
}

model UserLibrary {
  id           String  @id @default(cuid())
  name         String
  description  String?
  category     String
  thumbnailUrl String?
  nodeData     String  // JSON — DOMNode subtree
  tags         String  // Comma-separated tags
  embedding    Bytes?
  isPublic     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@map("user_library")
}

// ===========================================
// AI INTERACTION LOG
// ===========================================

model AIPromptLog {
  id           String  @id @default(cuid())
  projectId    String?
  pageId       String?
  prompt       String
  action       String
  response     String  // JSON — generated nodes
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@map("ai_prompt_logs")
}

// ===========================================
// AI SESSION MEMORY
// ===========================================

model AISession {
  id         String   @id @default(cuid())
  projectId  String
  pageId     String
  miniContext String  @default("") // Running summary of user actions
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages AISessionMessage[]

  @@unique([projectId, pageId])
  @@map("ai_sessions")
}

model AISessionMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // 'user' | 'assistant'
  content    String
  action     String?  // AIAction performed (e.g. "insert_section")
  createdAt  DateTime @default(now())

  session AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_session_messages")
}

// ===========================================
// AI MEMORY — PROJECT PROFILE
// ===========================================

model ProjectAIProfile {
  id              String   @id @default(cuid())
  projectId       String   @unique
  businessType    String   @default("")
  businessName    String   @default("")
  industry        String   @default("")
  targetAudience  String   @default("")
  tone            String   @default("")
  preferredStyle  String   @default("")
  preferredColors String   @default("{}") // JSON: hex array
  language        String   @default("en")
  contentThemes   String   @default("[]") // JSON: string array
  componentPrefs  String   @default("{}") // JSON: { type: count }
  memoryNotes     String   @default("[]") // JSON: { note, source, confidence }[]
  totalSessions   Int      @default(0)
  lastAnalysisAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_ai_profiles")
}

// ===========================================
// AI MEMORY — VECTOR EMBEDDINGS (pgvector)
// ===========================================

model VectorEmbedding {
  id             String    @id @default(cuid())
  projectId      String?
  userId         String?
  scope          String    // "user" | "project" | "global"
  category       String    // "preference" | "correction" | "pattern" | "fact" | "instruction" | "template" | "document" | "component_pattern"
  content        String    // The actual text content
  metadata       String    @default("{}") // JSON: { source, confidence, tags, sessionId, ... }
  embedding      Bytes?    // Binary embedding (fallback; actual vector via raw SQL)
  model          String?   // Which embedding model was used
  dimensions     Int       @default(768) // 768 for nomic-embed-text, 1536 for OpenAI
  sessionId      String?   // Which session produced this
  referencedAt   DateTime? @default(now())
  timesReferenced Int      @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([scope, category])
  @@index([projectId, scope])
  @@index([userId, scope])
  @@map("vector_embeddings")
}
