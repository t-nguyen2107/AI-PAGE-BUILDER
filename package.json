{
  "name": "ai-website-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate --config prisma/prisma.config.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "npx prisma db push --config prisma/prisma.config.ts",
    "db:generate": "npx prisma generate --config prisma/prisma.config.ts",
    "db:studio": "npx prisma studio --config prisma/prisma.config.ts",
    "db:seed": "DATABASE_URL=\"file:./dev.db\" npx tsx prisma/seed.ts",
    "postinstall": "npx prisma generate --config prisma/prisma.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
