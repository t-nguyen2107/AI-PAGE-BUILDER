    "@dnd-kit/utilities": "^3.2.2",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.1",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "langchain": "^1.2.39",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
